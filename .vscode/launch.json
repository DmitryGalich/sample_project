{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "main_app (clang + gdb)",
            "type": "cppdbg",
            "request": "launch",

            "program": "${command:cmake.launchTargetPath}",

            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",

            "environment": [],

            "externalConsole": false,

            "MIMode": "gdb",

            "preLaunchTask": "main_app_build_debug",

            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Intel disassembly",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}