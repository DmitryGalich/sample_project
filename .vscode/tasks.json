{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "main_app_build_debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Debug",
                "--target", "main_app"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "cmake_configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_TOOLCHAIN_FILE=build/conan_toolchain.cmake",
                "-B${workspaceFolder}/build",
                "${workspaceFolder}"
            ],
            "group": "build"
        }
    ]
}